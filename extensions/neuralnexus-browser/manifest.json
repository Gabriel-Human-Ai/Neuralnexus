{
  "manifest_version": 3,
  "name": "NeuralNexus Capture",
  "version": "0.1.0",
  "description": "Capture, review and preserve web references through NeuralNexus by explicit action.",
  "action": {
    "default_title": "NeuralNexus Capture",
    "default_popup": "popup/index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "permissions": ["activeTab", "storage", "contextMenus", "scripting", "sidePanel"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "icons": {
    "16": "icons/icon.svg",
    "32": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
