# Kopiere diese Datei zu ".env" und trage deine Keys ein.
# Du brauchst NICHT alle drei – einer reicht zum Start.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
DATABASE_URL="file:./dev.db"

# Real login via Clerk.
# Create these in the Clerk dashboard, then set the same values in Railway.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Railway production: create a persistent volume mounted at /data, then set:
# DATABASE_URL="file:/data/prod.db"
