# Kopiere diese Datei zu ".env" und trage deine Keys ein.
# Du brauchst NICHT alle drei – einer reicht zum Start.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
DATABASE_URL="file:./dev.db"

