{
  "name": "neuralnexus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "prisma generate && prisma db push",
    "dev": "prisma generate && prisma db push --skip-generate && next dev",
    "build": "prisma generate && next build",
    "db:ensure": "node scripts/ensure-sqlite-db.js",
    "migrate:deploy": "prisma migrate deploy",
    "backfill:default-profile": "node scripts/backfill-default-work-profile.js",
    "verify:profile-isolation": "node scripts/verify-profile-isolation.js",
    "start": "next start"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.17",
    "@prisma/client": "^5.22.0",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.462.0",
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shiki": "^4.3.1",
    "simplex-noise": "^4.0.3",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/three": "^0.177.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5"
  }
}
